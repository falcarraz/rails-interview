<div class="header-row">
  <h1>Todo Lists</h1>
  <%= link_to "+ New list", new_todo_list_path, role: "button" %>
</div>

<% if @todo_lists.any? %>
  <ul class="todo-lists">
    <% @todo_lists.each do |todo_list| %>
      <li>
        <%= link_to todo_list_path(todo_list) do %>
          <strong><%= todo_list.name %></strong>
          <span class="todo-list-count"><%= todo_list.items_count %></span>
        <% end %>
        <div class="todo-list-actions">
          <%= link_to "Edit", edit_todo_list_path(todo_list), class: "btn-inline" %>
          <%= button_to "Delete", todo_list_path(todo_list), method: :delete,
                class: "btn-inline danger",
                form: { data: { turbo_confirm: "Delete '#{todo_list.name}'?" } } %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="empty-state">No todo lists yet. Create one to get started!</p>
<% end %>
