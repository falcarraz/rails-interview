<%= form_with(model: todo_list) do |f| %>
  <% if todo_list.errors.any? %>
    <article style="padding:.75rem 1rem;background:#fff3cd;color:#664d03;border:1px solid #ffc107;">
      <% todo_list.errors.full_messages.each do |msg| %>
        <p style="margin:0;"><%= msg %></p>
      <% end %>
    </article>
  <% end %>

  <%= f.label :name %>
  <%= f.text_field :name, autofocus: true, placeholder: "List name" %>

  <div class="grid">
    <%= f.submit %>
    <%= link_to "Cancel", todo_lists_path, role: "button", class: "secondary outline" %>
  </div>
<% end %>
